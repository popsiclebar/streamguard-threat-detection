APP_NAME=streamguard
APP_ENV=development
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RAW_TOPIC=security-events.raw
KAFKA_DETECTION_TOPIC=security-detections.completed
KAFKA_DEAD_LETTER_TOPIC=security-events.dead-letter

REDIS_URL=redis://localhost:6379/0
ALERT_REPOSITORY_BACKEND=memory
RECENT_ALERT_LIMIT=100
ALERT_TTL_SECONDS=86400
PROCESSED_EVENT_TTL_SECONDS=86400
